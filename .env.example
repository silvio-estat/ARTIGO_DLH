# Copie este arquivo para `.env` (mesma pasta) antes de subir a stack:
#   cp .env.example .env        # Git Bash / Linux / macOS
#   Copy-Item .env.example .env # PowerShell
#
# Os valores abaixo já batem com os hardcoded em infra/trino/catalog/*.properties
# e infra/postgres/init/01_databases.sql — são credenciais de desenvolvimento local
# apenas (ver credenciais/credenciais-exemplo.md), não usar como referência para produção.

# MinIO (S3-compatible)
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=minio_pass_2026
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET_LAKEHOUSE=lakehouse

# PostgreSQL
POSTGRES_USER=dlh_admin
POSTGRES_PASSWORD=dlh_pass_2026
POSTGRES_DB_METASTORE=metastore_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Airflow — estes dois valores servem para desenvolvimento local; gere os seus
# próprios se for além disso (ex.: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
AIRFLOW__CORE__FERNET_KEY=sRgMM7x1Tekk02JzrOujrAcvKmeAVpZTHvXrAmZKq8U=
AIRFLOW__WEBSERVER__SECRET_KEY=e237de29a62c7851dc56c8ccdaa5e1813ead07ed

# OpenMetadata (perfil governance — só necessário com `docker compose --profile governance up -d`)
OM_ADMIN_EMAIL=admin@open-metadata.org
OM_AIRFLOW_DB=airflow_om_db
# Deixe vazio na primeira subida. Depois que o perfil governance estiver no ar
# (~3 min após o boot), rode: python scripts/setup_om_bot_token.py
# — preenche este valor automaticamente. Veja o README.md para o passo a passo completo.
OM_INGESTION_BOT_JWT=
